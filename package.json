{
  "name": "leonardomso-website",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "start": "astro preview",
    "lint": "biome lint ./src",
    "basehub": "basehub",
    "biome:lint": "biome lint ./src",
    "biome:format": "biome format --write ./src",
    "biome:write": "biome check --write ./src",
    "biome:fix:unsafe": "biome check --fix --unsafe ./src",
    "typecheck": "astro check",
    "clean": "git clean -xdf dist .astro node_modules",
    "preview": "bun run build && wrangler dev",
    "deploy": "bun run build && wrangler deploy",
    "run-all": "bun run biome:fix:unsafe && bun run biome:format && bun run biome:write && bun run biome:lint && bun run typecheck"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@dualmark/astro": "^0.6.0",
    "@dualmark/cloudflare": "^0.5.2",
    "@dualmark/converters": "^0.5.2",
    "@dualmark/core": "^0.5.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.3",
    "basehub": "^9.5.3",
    "cmdk": "^1.1.1",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/workers-types": "^4.20260518.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.7.0",
    "wrangler": "^4.92.0"
  }
}
