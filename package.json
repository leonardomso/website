{
  "name": "leonardomso-website",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "basehub": "basehub",
    "biome:lint": "biome lint ./src",
    "biome:format": "biome format --write ./src",
    "biome:write": "biome check --write ./src",
    "biome:fix:unsafe": "biome check --fix --unsafe ./src",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf .next .turbo node_modules",
    "run-all": "bun run biome:fix:unsafe && bun run biome:format && bun run biome:write && bun run biome:lint && bun run typecheck"
  },
  "dependencies": {
    "basehub": "^9.5.3",
    "cmdk": "^1.1.1",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.2"
  }
}
