---
import { CommandPalette } from "~/components/command-palette";
import { JsonLd, personSchema, websiteSchema } from "~/components/json-ld";
import { getAllPosts } from "~/lib/blog";
import "~/styles/globals.css";

interface Props {
  canonical?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  title?: string;
}

const SITE_URL = "https://www.leonardomso.com";
const DEFAULT_OG_IMAGE = `${SITE_URL}/opengraph-image`;

const {
  title = "Leonardo Maldonado",
  description = "Senior full-stack engineer based in Valencia, Spain. Previously sole engineer on Spaceship's domain search at Namecheap (3M+ domains sold). Creator of 33 JavaScript Concepts (66K+ stars). Currently building Strait.",
  canonical = SITE_URL,
  ogImage = DEFAULT_OG_IMAGE,
  ogType = "website",
} = Astro.props;

const posts = await getAllPosts();
const cmdkPosts = posts.map((p) => ({ title: p.title, slug: p.slug }));
---

<!doctype html>
<html lang="en" style="color-scheme: dark;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Leonardo Maldonado" />
    <meta name="theme-color" content="#050505" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Leonardo Maldonado RSS Feed" href={`${SITE_URL}/feed.xml`} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Leonardo Maldonado" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} — preview card`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@leonardomso" />
    <meta name="twitter:site" content="@leonardomso" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${title} — preview card`} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.ico" />
  </head>
  <body class="antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[10002] focus:rounded-lg focus:bg-fg focus:px-4 focus:py-2 focus:font-medium focus:text-bg focus:text-sm"
    >
      Skip to content
    </a>

    <JsonLd data={personSchema} />
    <JsonLd data={websiteSchema} />
    <CommandPalette posts={cmdkPosts} client:load />

    <div class="relative mx-auto w-full max-w-[680px] px-5 pt-10 pb-16 sm:px-6 sm:pt-16 sm:pb-24 md:px-0">
      <header class="mb-12 flex items-center justify-between gap-4 sm:mb-20">
        <a
          href="/"
          class="link-hover hidden py-1.5 font-mono text-fg-muted text-[13px] uppercase tracking-wide transition-colors hover:text-fg sm:inline-block"
        >
          Leonardo Maldonado
        </a>
        <nav aria-label="Main navigation" class="flex w-full justify-between gap-4 sm:w-auto sm:justify-end sm:gap-6">
          <a href="/" class="link-hover py-1.5 text-fg-tertiary text-[13px] uppercase tracking-wide transition-colors hover:text-fg">Home</a>
          <a href="/about" class="link-hover py-1.5 text-fg-tertiary text-[13px] uppercase tracking-wide transition-colors hover:text-fg">About</a>
          <a href="/projects" class="link-hover py-1.5 text-fg-tertiary text-[13px] uppercase tracking-wide transition-colors hover:text-fg">Projects</a>
          <a href="/blog" class="link-hover py-1.5 text-fg-tertiary text-[13px] uppercase tracking-wide transition-colors hover:text-fg">Blog</a>
          <a href="/resume" class="link-hover py-1.5 text-fg-tertiary text-[13px] uppercase tracking-wide transition-colors hover:text-fg">Resume</a>
        </nav>
      </header>

      <main id="main-content">
        <slot />
      </main>

      <footer class="mt-20 flex flex-col-reverse items-start justify-between gap-4 border-surface-border border-t pt-8 sm:mt-32 sm:flex-row sm:items-center sm:gap-0">
        <p class="font-mono text-fg-tertiary text-[11px] tracking-wider">© 2026</p>
        <nav aria-label="Social links" class="flex gap-6">
          <a href="https://github.com/leonardomso" target="_blank" rel="noopener noreferrer" class="link-hover py-1.5 text-fg-tertiary text-[12px] tracking-wide transition-colors hover:text-fg">GitHub</a>
          <a href="https://x.com/leonardomso" target="_blank" rel="noopener noreferrer" class="link-hover py-1.5 text-fg-tertiary text-[12px] tracking-wide transition-colors hover:text-fg">X</a>
          <a href="https://www.linkedin.com/in/leonardomso/" target="_blank" rel="noopener noreferrer" class="link-hover py-1.5 text-fg-tertiary text-[12px] tracking-wide transition-colors hover:text-fg">LinkedIn</a>
        </nav>
      </footer>
    </div>

    <script is:inline async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
  </body>
</html>
