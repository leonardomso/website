---
import BaseLayout from "~/layouts/base-layout.astro";
---

<BaseLayout title="404 · Leonardo Maldonado" description="Page not found.">
  <div class="flex min-h-[60vh] flex-col items-center justify-center text-center">
    <p class="mb-4 font-mono text-fg-tertiary text-[12px] uppercase tracking-[0.25em]">404</p>
    <h1 class="font-semibold text-fg text-[clamp(2rem,5vw,3rem)] leading-[1.1] tracking-[-0.03em]">Page not found</h1>
    <p class="mt-6 max-w-[360px] text-fg-secondary text-[15px] leading-[1.75]">The page you&apos;re looking for doesn&apos;t exist or has been moved.</p>
    <a href="/" class="link-hover mt-8 font-mono text-fg-muted text-[13px] tracking-wide transition-colors hover:text-fg">Back to home</a>
  </div>
</BaseLayout>
