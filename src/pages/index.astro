---
import { Contact } from "~/components/contact";
import { Experience } from "~/components/experience";
import { Stack } from "~/components/stack";
import { Ventures } from "~/components/ventures";
import { Writing } from "~/components/writing";
import BaseLayout from "~/layouts/base-layout.astro";
---

<BaseLayout
  title="Leonardo Maldonado · Senior Full-Stack Engineer"
  description="Senior full-stack engineer based in Valencia, Spain. Previously sole engineer on Spaceship's domain search at Namecheap (3M+ domains sold). Creator of 33 JavaScript Concepts (66K+ stars). Currently building Strait."
>
  <div>
    <section class="mb-24 sm:mb-32">
      <p class="mb-4 font-mono text-fg-tertiary text-[12px] uppercase tracking-[0.25em]">
        Senior Full-Stack Engineer · Valencia, Spain
      </p>
      <h1 class="font-semibold text-fg text-[clamp(2.5rem,6vw,4rem)] leading-[1.05] tracking-[-0.035em]">
        Leonardo
        <br />
        Maldonado
      </h1>
      <p class="mt-8 max-w-[480px] text-fg-secondary text-[16px] leading-[1.75] sm:text-[15px]">
        Senior full-stack engineer working with TypeScript, React, Node.js, and Go. Previously the sole engineer on Spaceship&apos;s
        <a class="link-hover text-fg-muted transition-colors hover:text-fg" href="https://www.spaceship.com/domain-search/" rel="noopener noreferrer" target="_blank">
          domain search
        </a>
        at
        <a class="link-hover text-fg-muted transition-colors hover:text-fg" href="https://www.namecheap.com" rel="noopener noreferrer" target="_blank">
          Namecheap
        </a>, helping sell 3M+ domains. Currently building
        <a class="link-hover text-fg-muted transition-colors hover:text-fg" href="https://strait.dev" rel="noopener noreferrer" target="_blank">
          Strait
        </a>, an agentic workflow orchestration platform.
      </p>
    </section>

    <section class="mb-20 sm:mb-28">
      <div class="mb-10 flex items-center gap-4">
        <span class="font-mono text-fg-tertiary text-[11px] uppercase tracking-[0.2em]">Experience</span>
        <div class="section-divider flex-1" />
      </div>
      <Experience />
    </section>

    <section class="mb-20 sm:mb-28">
      <div class="mb-10 flex items-center gap-4">
        <span class="font-mono text-fg-tertiary text-[11px] uppercase tracking-[0.2em]">Writing</span>
        <div class="section-divider flex-1" />
      </div>
      <Writing />
    </section>

    <section class="mb-20 sm:mb-28">
      <div class="mb-10 flex items-center gap-4">
        <span class="font-mono text-fg-tertiary text-[11px] uppercase tracking-[0.2em]">Stack</span>
        <div class="section-divider flex-1" />
      </div>
      <Stack />
    </section>

    <section class="mb-20 sm:mb-28">
      <div class="mb-10 flex items-center gap-4">
        <span class="font-mono text-fg-tertiary text-[11px] uppercase tracking-[0.2em]">Ventures</span>
        <div class="section-divider flex-1" />
      </div>
      <Ventures />
    </section>

    <section>
      <div class="mb-10 flex items-center gap-4">
        <span class="font-mono text-fg-tertiary text-[11px] uppercase tracking-[0.2em]">Contact</span>
        <div class="section-divider flex-1" />
      </div>
      <Contact />
    </section>
  </div>
</BaseLayout>
